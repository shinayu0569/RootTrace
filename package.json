{
  "name": "roottrace",
  "private": true,
  "version": "3.2.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && npx esbuild server.ts --bundle --platform=node --target=node24 --packages=external --outfile=dist/server.cjs --format=cjs",
    "lint": "tsc --noEmit",
    "preview": "vite preview",
    "start": "node dist/server.cjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@rollup/rollup-linux-x64-gnu": "^4.60.1",
    "@uiw/react-codemirror": "^4.25.9",
    "axios": "^1.13.6",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "lucide-react": "^0.577.0",
    "papaparse": "^5.5.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.14.0",
    "@types/papaparse": "^5.5.2",
    "@vitejs/plugin-react": "^5.0.0",
    "esbuild": "^0.27.4",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.2"
  },
